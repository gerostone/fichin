generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserGameStatus {
  WISHLIST
  PLAYED
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  username     String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  reviews      Review[]
  userGames    UserGame[]

  @@index([email])
  @@index([username])
}

model Game {
  id           String     @id @default(uuid())
  externalId   String?    @unique
  title        String
  slug         String     @unique
  coverUrl     String?
  releaseDate  DateTime?
  genres       String[]   @default([])
  platforms    String[]   @default([])
  summary      String?
  ratingGlobal Float?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  reviews      Review[]
  userGames    UserGame[]

  @@index([title])
  @@index([slug])
}

model UserGame {
  id        String         @id @default(uuid())
  userId    String
  gameId    String
  status    UserGameStatus
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([status])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  score     Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@index([userId])
}
